*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial;
}

body{
    background-color: #f2f4f8;
}

.container{
    height: 100vh;

    display: flex;
    flex-direction: column;
}

.topo{
    background: linear-gradient(to right, #1f8fff, #45a3ff);

    color: white;

    padding: 20px;

    display: flex;
    justify-content: space-between;
    align-items: center;
}

.botao-login{
    padding: 10px 20px;

    border: none;
    border-radius: 10px;

    background-color: white;
    color: #1f8fff;

    cursor: pointer;
}

.conteudo{
    flex: 1;

    display: flex;
    justify-content: center;
    align-items: center;
}

.caixa{
    background-color: white;

    width: 500px;

    padding: 40px;

    border-radius: 20px;

    text-align: center;

    box-shadow: 0px 2px 10px rgba(0,0,0,0.1);
}

.caixa h2{
    margin-bottom: 20px;
}

.caixa p{
    color: gray;

    margin-bottom: 30px;
}

.acoes{
    display: flex;
    justify-content: center;

    gap: 20px;
}

.acoes button{
    padding: 12px 20px;

    border: none;
    border-radius: 10px;

    background-color: #1f8fff;
    color: white;

    cursor: pointer;
}

.acoes button:hover{
    background-color: #0f7ae5;
}
